{% capture submit_button %}
  <button type="submit" class="button customer-survey__submit">
    {{ section.settings.submit_label | default: 'Submit Survey' }}
  </button>
{% endcapture %}

{% assign form_id = section.id | prepend: 'SurveyForm-' %}

{%- assign rating_options = 'Excellent,Above Average,Average,Below Average,Poor' | split: ',' -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  style="
    {% if section.settings.section_height == 'custom' %}
      --section-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
      --section-min-height: 100svh;
    {% elsif section.settings.section_height != '' %}
      --section-min-height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}
  "
>
  <div
    class="border-style custom-section-content"
    style="{% render 'border-override', settings: section.settings %}"
  >
    <div
      class="
        spacing-style
        layout-panel-flex
        layout-panel-flex--{{ section.settings.content_direction }}
        section-content-wrapper
        {% if section.settings.vertical_on_mobile %}mobile-column{% endif %}
      "
      style="
        {% render 'layout-panel-style', settings: section.settings %}
        {% render 'spacing-style', settings: section.settings %}
      "
    >
      {%- form 'contact', id: form_id, class: 'customer-survey' -%}
        <!-- Left Column: Title/Description or Success Message -->
        <div class="customer-survey__left">
          {%- if form.posted_successfully? -%}
            <div class="customer-survey__success" tabindex="-1" autofocus>
              {{- 'icon-checkmark.svg' | inline_asset_content -}}
              <h3 class="customer-survey__success-heading">
                {{ section.settings.success_heading | default: 'Thank you!' }}
              </h3>
              <p class="customer-survey__success-message">
                {{ section.settings.success_message | default: 'Your feedback has been submitted. We appreciate your time.' }}
              </p>
            </div>
          {%- else -%}
            <div class="customer-survey__header">
              {%- if section.settings.heading != blank -%}
                <h3 class="customer-survey__heading h3">{{ section.settings.heading }}</h3>
              {%- endif -%}
              {%- if section.settings.description != blank -%}
                <div class="customer-survey__description rte">{{ section.settings.description }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        <!-- Right Column: Survey Questions or Empty on Success -->
        <div class="customer-survey__right">
          {%- unless form.posted_successfully? -%}
            {%- if form.errors -%}
              <div class="customer-survey__error" tabindex="-1" autofocus>
                {{- 'icon-error.svg' | inline_asset_content -}}
                {{- form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email -}}
              </div>
            {%- endif -%}

            <div class="customer-survey__sections">
              <!-- Section 1: Phone Issues -->
              <fieldset class="customer-survey__section">
                <legend class="customer-survey__section-title h4">Phone Issues</legend>

                <div class="customer-survey__question">
                  <p class="customer-survey__question-text">Phone calls answered promptly</p>
                  <div class="customer-survey__options">
                    {%- for option in rating_options -%}
                      <label class="customer-survey__option">
                        <input
                          type="radio"
                          name="contact[Phone calls answered promptly]"
                          value="{{ option }}"
                          class="customer-survey__radio"
                        >
                        <span class="customer-survey__option-label">{{ option }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>

                <div class="customer-survey__question">
                  <p class="customer-survey__question-text">Courtesy of greeting</p>
                  <div class="customer-survey__options">
                    {%- for option in rating_options -%}
                      <label class="customer-survey__option">
                        <input
                          type="radio"
                          name="contact[Courtesy of greeting]"
                          value="{{ option }}"
                          class="customer-survey__radio"
                        >
                        <span class="customer-survey__option-label">{{ option }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>

                <div class="customer-survey__question">
                  <p class="customer-survey__question-text">On hold time</p>
                  <div class="customer-survey__options">
                    {%- for option in rating_options -%}
                      <label class="customer-survey__option">
                        <input
                          type="radio"
                          name="contact[On hold time]"
                          value="{{ option }}"
                          class="customer-survey__radio"
                        >
                        <span class="customer-survey__option-label">{{ option }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>
              </fieldset>

              <!-- Section 2: Sales/Service Issues -->
              <fieldset class="customer-survey__section">
                <legend class="customer-survey__section-title h4">Sales/Service Issues</legend>

                <div class="customer-survey__question">
                  <p class="customer-survey__question-text">Courtesy</p>
                  <div class="customer-survey__options">
                    {%- for option in rating_options -%}
                      <label class="customer-survey__option">
                        <input
                          type="radio"
                          name="contact[Sales Courtesy]"
                          value="{{ option }}"
                          class="customer-survey__radio"
                        >
                        <span class="customer-survey__option-label">{{ option }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>

                <div class="customer-survey__question">
                  <p class="customer-survey__question-text">Paperwork processing</p>
                  <div class="customer-survey__options">
                    {%- for option in rating_options -%}
                      <label class="customer-survey__option">
                        <input
                          type="radio"
                          name="contact[Paperwork processing]"
                          value="{{ option }}"
                          class="customer-survey__radio"
                        >
                        <span class="customer-survey__option-label">{{ option }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>

                <div class="customer-survey__question">
                  <p class="customer-survey__question-text">Product knowledge</p>
                  <div class="customer-survey__options">
                    {%- for option in rating_options -%}
                      <label class="customer-survey__option">
                        <input
                          type="radio"
                          name="contact[Product knowledge]"
                          value="{{ option }}"
                          class="customer-survey__radio"
                        >
                        <span class="customer-survey__option-label">{{ option }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>
              </fieldset>

              <!-- Section 3: Upon Receipt of Material -->
              <fieldset class="customer-survey__section">
                <legend class="customer-survey__section-title h4">Upon Receipt of Material</legend>

                <div class="customer-survey__question">
                  <p class="customer-survey__question-text">Condition of product</p>
                  <div class="customer-survey__options">
                    {%- for option in rating_options -%}
                      <label class="customer-survey__option">
                        <input
                          type="radio"
                          name="contact[Condition of product]"
                          value="{{ option }}"
                          class="customer-survey__radio"
                        >
                        <span class="customer-survey__option-label">{{ option }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>

                <div class="customer-survey__question">
                  <p class="customer-survey__question-text">Quantity accuracy</p>
                  <div class="customer-survey__options">
                    {%- for option in rating_options -%}
                      <label class="customer-survey__option">
                        <input
                          type="radio"
                          name="contact[Quantity accuracy]"
                          value="{{ option }}"
                          class="customer-survey__radio"
                        >
                        <span class="customer-survey__option-label">{{ option }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>

                <div class="customer-survey__question">
                  <p class="customer-survey__question-text">Product Identification</p>
                  <div class="customer-survey__options">
                    {%- for option in rating_options -%}
                      <label class="customer-survey__option">
                        <input
                          type="radio"
                          name="contact[Product Identification]"
                          value="{{ option }}"
                          class="customer-survey__radio"
                        >
                        <span class="customer-survey__option-label">{{ option }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>

                <div class="customer-survey__question">
                  <p class="customer-survey__question-text">Packing list accuracy</p>
                  <div class="customer-survey__options">
                    {%- for option in rating_options -%}
                      <label class="customer-survey__option">
                        <input
                          type="radio"
                          name="contact[Packing list accuracy]"
                          value="{{ option }}"
                          class="customer-survey__radio"
                        >
                        <span class="customer-survey__option-label">{{ option }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>

                <div class="customer-survey__question">
                  <p class="customer-survey__question-text">Documentation accuracy</p>
                  <div class="customer-survey__options">
                    {%- for option in rating_options -%}
                      <label class="customer-survey__option">
                        <input
                          type="radio"
                          name="contact[Documentation accuracy]"
                          value="{{ option }}"
                          class="customer-survey__radio"
                        >
                        <span class="customer-survey__option-label">{{ option }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>
              </fieldset>

              <!-- Section 4: Product Quality -->
              <fieldset class="customer-survey__section">
                <legend class="customer-survey__section-title h4">Product Quality</legend>

                <div class="customer-survey__question">
                  <p class="customer-survey__question-text">Overall quality</p>
                  <div class="customer-survey__options">
                    {%- for option in rating_options -%}
                      <label class="customer-survey__option">
                        <input
                          type="radio"
                          name="contact[Overall quality]"
                          value="{{ option }}"
                          class="customer-survey__radio"
                        >
                        <span class="customer-survey__option-label">{{ option }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>

                <div class="customer-survey__question">
                  <p class="customer-survey__question-text">Overall appearance</p>
                  <div class="customer-survey__options">
                    {%- for option in rating_options -%}
                      <label class="customer-survey__option">
                        <input
                          type="radio"
                          name="contact[Overall appearance]"
                          value="{{ option }}"
                          class="customer-survey__radio"
                        >
                        <span class="customer-survey__option-label">{{ option }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>
              </fieldset>

              <!-- Section 5: General Overall Perception -->
              <fieldset class="customer-survey__section">
                <legend class="customer-survey__section-title h4">General Overall Perception</legend>

                <div class="customer-survey__question">
                  <p class="customer-survey__question-text">Communication</p>
                  <div class="customer-survey__options">
                    {%- for option in rating_options -%}
                      <label class="customer-survey__option">
                        <input
                          type="radio"
                          name="contact[Communication]"
                          value="{{ option }}"
                          class="customer-survey__radio"
                        >
                        <span class="customer-survey__option-label">{{ option }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>
              </fieldset>

              <!-- Hidden email field for contact form requirement -->
              <input type="hidden" name="contact[email]" value="survey@jdlindustries.com">

              {{ submit_button }}
            </div>
          {%- endunless -%}
        </div>
      {%- endform -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .customer-survey {
    display: contents;
  }

  .customer-survey__left,
  .customer-survey__right {
    flex: 1;
    width: 100%;
  }

  .customer-survey__header {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .customer-survey__heading {
    margin: 0;
  }

  .customer-survey__description {
    margin: 0;
  }

  .customer-survey__sections {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xl);
  }

  .customer-survey__section {
    border: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .customer-survey__section-title {
    margin: 0;
    padding: 0 0 var(--gap-sm) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .customer-survey__question {
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
  }

  .customer-survey__question-text {
    margin: 0;
    font-weight: 500;
  }

  .customer-survey__options {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-sm) var(--gap-lg);
  }

  .customer-survey__option {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
    cursor: pointer;
  }

  .customer-survey__radio {
    width: 18px;
    height: 18px;
    margin: 0;
    cursor: pointer;
    accent-color: var(--color-foreground);
  }

  .customer-survey__option-label {
    font-size: 0.9em;
    white-space: nowrap;
  }

  .customer-survey__error,
  .customer-survey__success {
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
  }

  .customer-survey__error {
    flex-direction: row;
    align-items: center;
    gap: var(--gap-xs);
  }

  .customer-survey__success svg {
    width: 32px;
    height: 32px;
    color: var(--color-foreground);
  }

  .customer-survey__success-heading {
    margin: 0;
  }

  .customer-survey__success-message {
    margin: 0;
  }

  .customer-survey__submit {
    align-self: flex-start;
    margin-top: var(--gap-md);
  }

  /* Responsive: stack options vertically on smaller screens */
  @media screen and (max-width: 600px) {
    .customer-survey__options {
      flex-direction: column;
      gap: var(--gap-xs);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Customer Feedback Survey",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer Feedback Survey"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>We value your feedback. Please take a moment to rate your experience with us.</p>"
    },
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "Submit Survey"
    },
    {
      "type": "header",
      "content": "Success Message"
    },
    {
      "type": "text",
      "id": "success_heading",
      "label": "Success heading",
      "default": "Thank you!"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Your feedback has been submitted. We appreciate your time."
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "content_direction",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "column",
          "label": "t:options.vertical"
        },
        {
          "value": "row",
          "label": "t:options.horizontal"
        }
      ],
      "default": "row"
    },
    {
      "type": "checkbox",
      "id": "vertical_on_mobile",
      "label": "t:settings.vertical_on_mobile",
      "default": true,
      "visible_if": "{{ section.settings.content_direction == 'row' }}"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        },
        {
          "value": "space-between",
          "label": "t:options.space_between"
        }
      ],
      "default": "flex-start",
      "visible_if": "{{ section.settings.content_direction == 'row' }}"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "t:settings.position",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.top"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.bottom"
        }
      ],
      "default": "flex-start",
      "visible_if": "{{ section.settings.content_direction == 'row' }}"
    },
    {
      "type": "select",
      "id": "horizontal_alignment_flex_direction_column",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        }
      ],
      "default": "flex-start",
      "visible_if": "{{ section.settings.content_direction != 'row' }}"
    },
    {
      "type": "select",
      "id": "vertical_alignment_flex_direction_column",
      "label": "t:settings.position",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.top"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.bottom"
        },
        {
          "value": "space-between",
          "label": "t:options.space_between"
        }
      ],
      "default": "flex-start",
      "visible_if": "{{ section.settings.content_direction == 'column' }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "t:content.size"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "t:settings.height",
      "options": [
        {
          "value": "",
          "label": "t:options.auto"
        },
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "medium",
          "label": "t:options.medium"
        },
        {
          "value": "large",
          "label": "t:options.large"
        },
        {
          "value": "full-screen",
          "label": "t:options.full_screen"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": ""
    },
    {
      "type": "range",
      "id": "section_height_custom",
      "label": "t:settings.custom_height",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 50,
      "unit": "%",
      "visible_if": "{{ section.settings.section_height == 'custom' }}"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.borders",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "px",
      "label": "t:settings.border_width",
      "default": 1,
      "visible_if": "{{ section.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.border_opacity",
      "default": 100,
      "visible_if": "{{ section.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Customer Feedback Survey",
      "category": "t:categories.forms"
    }
  ]
}
{% endschema %}
